generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientService {
  META_ADS
  TIKTOK_ADS
  GOOGLE_ADS
  SOCIAL_MEDIA_MANAGEMENT
  CONTENT_CREATION
  SHOPIFY_STORE
  WEBSITE_DEVELOPMENT
  WEB_APPLICATION
  MOBILE_APPLICATION
  BRANDING
  OTHER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum PaymentMethod {
  CASH
  BANK
  WHISH
  OMT
  TRANSFER
  OTHER
}

enum PaymentFrequency {
  ONE_TIME
  MONTHLY
  YEARLY
}

enum ExpenseCategory {
  OFFICE
  SOFTWARE
  ADS
  FREELANCER
  EMPLOYEE
  INTERNET
  PHONE
  TRANSPORTATION
  EQUIPMENT
  UTILITIES
  MARKETING
  OTHER
}

enum AdvanceStatus {
  OPEN
  PAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AttachmentEntityType {
  CLIENT
  INCOME
  EXPENSE
  INVOICE
  ADVANCE
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  PAID
  ATTACHED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Client {
  id                String        @id @default(cuid())
  name              String
  company           String?
  phone             String?
  email             String?
  services          ClientService[]
  monthlyFee        Decimal       @db.Decimal(12, 2)
  billingFrequency  PaymentFrequency @default(MONTHLY)
  currency          String        @default("USD")
  status            ClientStatus  @default(ACTIVE)
  contractStartDate DateTime
  notes             String?
  income            Income[]
  invoices          Invoice[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([billingFrequency])
  @@map("clients")
}

model Income {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("USD")
  date            DateTime
  paymentMethod   PaymentMethod
  frequency       PaymentFrequency @default(ONE_TIME)
  referenceNumber String?
  description     String?
  invoiceNumber   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientId])
  @@index([invoiceId])
  @@index([date])
  @@index([frequency])
  @@map("income")
}

model Invoice {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber String           @unique
  amount        Decimal          @db.Decimal(12, 2)
  paidAmount    Decimal          @default(0) @db.Decimal(12, 2)
  currency      String           @default("USD")
  issueDate     DateTime
  dueDate       DateTime
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  autoGenerated Boolean          @default(false)
  status        InvoiceStatus    @default(SENT)
  description   String?
  notes         String?
  payments      InvoicePayment[]
  income        Income[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([clientId])
  @@index([clientId, billingPeriodStart, billingPeriodEnd])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoicePayment {
  id             String        @id @default(cuid())
  invoiceId      String
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  date           DateTime
  paymentMethod  PaymentMethod
  referenceNumber String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([invoiceId])
  @@index([date])
  @@map("invoice_payments")
}

model Expense {
  id             String          @id @default(cuid())
  title          String
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("USD")
  category       ExpenseCategory
  paymentMethod  PaymentMethod
  frequency      PaymentFrequency @default(ONE_TIME)
  date           DateTime
  vendor         String?
  receiptNumber  String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([category])
  @@index([date])
  @@index([frequency])
  @@map("expenses")
}

model OwnerAdvance {
  id                 String             @id @default(cuid())
  title              String
  amount             Decimal            @db.Decimal(12, 2)
  currency           String             @default("USD")
  date               DateTime
  source             String?
  plannedInstallments Int?
  installmentAmount  Decimal?           @db.Decimal(12, 2)
  nextDueDate         DateTime?
  notes              String?
  status             AdvanceStatus      @default(OPEN)
  repayments         AdvanceRepayment[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([date])
  @@index([status])
  @@map("owner_advances")
}

model AdvanceRepayment {
  id             String        @id @default(cuid())
  advanceId      String
  advance        OwnerAdvance  @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  date           DateTime
  paymentMethod  PaymentMethod
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([advanceId])
  @@index([date])
  @@map("advance_repayments")
}

model Attachment {
  id          String               @id @default(cuid())
  entityType  AttachmentEntityType
  entityId    String
  title       String
  url         String
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([entityType, entityId])
  @@map("attachments")
}

model ActivityLog {
  id          String         @id @default(cuid())
  action      ActivityAction
  entityType  String
  entityId    String?
  title       String
  details     String?
  createdAt   DateTime       @default(now())

  @@index([entityType])
  @@index([createdAt])
  @@map("activity_logs")
}
